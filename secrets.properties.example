# =====================================================================
# Phase 7 · Step 7.2 — `secrets.properties.example`
# =====================================================================
#
# Copy this file to `secrets.properties` (gitignored) and drop in real
# values. The EncryptSecretsTask Gradle task reads this at build time,
# encrypts each value with AES-256-GCM, and generates
# EncryptedConstants.kt as a build-artifact (never committed).
#
# When a key is absent the task falls back to the hardcoded default so
# `assembleDebug` works for developers without prod creds.
#
# SENTRY_DSN is NOT listed here — it comes from signing.properties
# (APP_SENTRY_DSN) which is already gitignored and shared with the
# Sentry Gradle plugin.
# =====================================================================

# --- API endpoints -------------------------------------------------------
API_BASE_URL=https://learngermanwith.fun/api
API_CONFIG_URL=https://learngermanwith.fun/api/config
UPDATE_URL=https://learngermanwith.fun/update

# --- Telegram community link ---------------------------------------------
TELEGRAM_LINK=https://t.me/sportstream
