<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Step 1.4 — runtime capabilities. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- POST_NOTIFICATIONS is runtime-requested at API 33+ but must be declared. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Phase 4 · Step 4.2 — Media3 / ExoPlayer requirements (Step 4.6 foreground service also uses this). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <application
        android:name=".SportStreamApp"
        android:allowBackup="false"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:roundIcon="@android:drawable/sym_def_app_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.SportStream">

        <activity
            android:name=".ui.activities.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Step 3.2 will wire MainActivity as the post-splash destination. -->
        <activity
            android:name=".ui.activities.MainActivity"
            android:exported="false" />

        <!-- Phase 4 · Step 4.2 — PlayerActivity implements Media3 ExoPlayer
             playback with custom controls overlay, PiP support (API 26+),
             and immersive mode. The android:configChanges avoids a full
             Activity recreate on rotation / PiP entry/exit (the activity
             listens to onPictureInPictureModeChanged directly). -->
        <activity
            android:name=".ui.activities.PlayerActivity"
            android:exported="false"
            android:supportsPictureInPicture="true"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout" />
    </application>
</manifest>
