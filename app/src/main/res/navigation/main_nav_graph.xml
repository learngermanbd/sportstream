<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 3 · Step 3.2 — Navigation graph for the post-splash Main screen.
    Hosts the 4 bottom-nav destinations (Home / Categories / Favorites / Settings).
    Destination IDs MUST match menu item IDs in res/menu/bottom_nav_menu.xml —
    that is what makes BottomNavigationView.setupWithNavController() resolve
    taps without any manual navController.navigate(...) wiring.
    Deep-link / action graphs land in Steps 3.x–5.x as the Live / Player /
    Settings screens actually route to other screens.
-->
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.sportstream.app.ui.fragments.HomeFragment"
        android:label="@string/main_nav_home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/categoriesFragment"
        android:name="com.sportstream.app.ui.fragments.CategoriesFragment"
        android:label="@string/main_nav_categories"
        tools:layout="@layout/fragment_categories" />

    <fragment
        android:id="@+id/favoritesFragment"
        android:name="com.sportstream.app.ui.fragments.FavoritesFragment"
        android:label="@string/main_nav_favorites"
        tools:layout="@layout/fragment_favorites" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.sportstream.app.ui.fragments.SettingsFragment"
        android:label="@string/main_nav_settings"
        tools:layout="@layout/fragment_settings" />

    <!--
        Phase 3 · Step 3.5 — Highlights destination.

        Not in bottom_nav_menu.xml (BottomNav is reserved for the 4
        always-visible tabs Home / Categories / Favorites / Settings).
        Reachable from the Step 5.5 Drawer menu (drawer item "Highlights"
        -> navController.navigate(R.id.highlightsFragment)) and from any
        future PlayerActivity intent that wants to surface related
        highlights as a sub-list.
    -->
    <fragment
        android:id="@+id/highlightsFragment"
        android:name="com.sportstream.app.ui.fragments.HighlightsFragment"
        android:label="@string/fragment_highlights_header"
        tools:layout="@layout/fragment_highlights" />

</navigation>
