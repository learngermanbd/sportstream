<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 5 · Step 5.5 — Notice layout.

    Surfaces:
      • Header (title + subtitle)         — always visible
      • noticeBodyCard (scrollable card)  — Success(non-empty noticeText)
      • noticeEmptyState (icon + text)    — Success(empty noticeText)
      • noticeErrorCard (glass red card)  — Error
      • noticeProgress (CircularProgressIndicator) — Loading / Idle
      • noticeRefreshFab (Extended FAB)   — always visible, force-refresh

    The header + FAB stay visible across every render-state because the
    user needs both context ("this is the Notice screen") and an
    immediate "refresh-now" affordance even when the data is missing.
    The four data surfaces (body / empty / error / progress) are
    mutually exclusive — `Fragment.showOnly(...)` flips them.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg">

    <!-- Header -->
    <TextView
        android:id="@+id/noticeHeaderTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:fontFamily="@font/poppins_regular"
        android:letterSpacing="0.18"
        android:text="@string/fragment_notice_title"
        android:textColor="@color/primary"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/noticeHeaderSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="24dp"
        android:alpha="0.85"
        android:fontFamily="@font/poppins_regular"
        android:text="@string/fragment_notice_subtitle"
        android:textColor="@color/text_muted"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/noticeHeaderTitle" />

    <!-- Notice body card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/noticeBodyCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="96dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/glass_primary_border"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/noticeHeaderSubtitle">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fadeScrollbars="false"
            android:scrollbarStyle="outsideOverlay">

            <TextView
                android:id="@+id/noticeBodyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:lineSpacingExtra="6dp"
                android:padding="20dp"
                android:textColor="@color/text"
                android:textSize="15sp"
                tools:text="We'll be performing scheduled maintenance on Sunday at 02:00 UTC. Streams may be unavailable for up to 30 minutes." />

        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/noticeEmptyState"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:alpha="0.6"
            android:contentDescription="@null"
            android:src="@drawable/ic_notice" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/poppins_regular"
            android:text="@string/notice_empty_title"
            android:textColor="@color/text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:alpha="0.85"
            android:fontFamily="@font/poppins_regular"
            android:text="@string/notice_empty_subtitle"
            android:textColor="@color/text_muted"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/noticeProgress"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:indeterminateTint="@color/primary"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Error card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/noticeErrorCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/glass_red"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/live_red"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:text="@string/notice_error_title"
                android:textColor="@color/live_red"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/noticeErrorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:alpha="0.85"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text"
                android:textSize="13sp"
                tools:text="Network unavailable" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/noticeRetryButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/notice_error_retry"
                app:backgroundTint="@color/primary"
                app:cornerRadius="10dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Refresh FAB: always visible so the user has an escape hatch from any state. -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/noticeRefreshFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="24dp"
        android:text="@string/notice_refresh"
        android:textColor="@color/dark_bg"
        app:backgroundTint="@color/primary"
        app:icon="@drawable/ic_notice"
        app:iconTint="@color/dark_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
