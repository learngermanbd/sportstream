<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 3 · Step 3.2 — Settings tab placeholder.
    Step 5.5 wraps the whole MainActivity in a DrawerLayout (Navigation Drawer
    + 9-item drawer menu: Network Stream, Playlists, Floating Player, Video
    Quality, Notice, Join Us, Share, Update, Exit) + Step 5.6 adds a Toolbar
    with debounced search. Both will be added on top of this fragment, not in
    place of it.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_regular"
        android:letterSpacing="0.18"
        android:text="@string/fragment_settings_title"
        android:textColor="@color/primary"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:alpha="0.85"
        android:fontFamily="@font/poppins_regular"
        android:letterSpacing="0.04"
        android:text="@string/fragment_settings_subtitle"
        android:textColor="@color/text_muted"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/title" />

</androidx.constraintlayout.widget.ConstraintLayout>
