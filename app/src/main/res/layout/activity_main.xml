<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 3 · Step 3.2 — MainActivity layout (replaces Step 3.1 placeholder).
    Hosts a NavHostFragment + a Material 3 BottomNavigationView styled with
    @style/SportStream.BottomNav (defined in styles.xml since Step 1.5).
    The DrawerLayout + Toolbar + Search scaffold lands in Steps 5.5 / 5.6
    and will be wrapped around this root.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash">

    <!-- NavHostFragment hosts res/navigation/main_nav_graph.xml (4 destinations). -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/navHostFragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:defaultNavHost="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:navGraph="@navigation/main_nav_graph" />

    <!-- Bottom navigation. Style gives it glass-primary active indicator
         + text_muted item icon/text tint + card_bg background. -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        style="@style/SportStream.BottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>
